enable-nolib-creation: no

externals:
  libs/LibStub:
    url: svn://svn.wowace.com/wow/libstub/mainline/trunk
  libs/DRList-1.0:
    url: git://github.com/wardz/DRList-1.0
    tag: latest
  Diminish_Options/libs/PhanxConfig-Dropdown:
    url: git://github.com/phanx-wow/PhanxConfig-Dropdown

move-folders:
  Diminish/Diminish_Options: Diminish_Options

manual-changelog: CHANGELOG.txt
wowi-create-changelog=no

ignore:
  - README.md
  - .travis.yml
  - .luacheckrc
  - libs/LibStub/LibStub.toc
  - libs/LibStub/tests
